<style>
.navbar {
  background: rgba(255,255,255,0.95) !important;
  backdrop-filter: blur(10px);
  padding: 0.8rem 1rem;
  z-index: 1000;
  }
.navbar{
  background: rgba(255,255,255,0.8) !important;
  backdrop-filter: blur(10px);
}
.navbar-brand {
  font-size: 1.6rem;
  color: #fe424d !important;
}

.search-bar input {
  border-radius: 50px;
  min-width: 250px;
  padding-left: 1rem;
  margin-left: 5rem;
  }

.search-btn {
  border-radius: 50px;
  padding: 0.5rem 1rem;
}

.signup-btn {
  background-color: black;
  color: white !important;
  border-radius: 50px;
  padding: 0.45rem 1rem !important;
  margin-right: 0.5rem;
  transition: 0.3s;
}

.signup-btn:hover {
  background-color: #222;
}

.login-btn {
  background-color: #fe424d;
  color: white !important;
  border-radius: 50px;
  padding: 0.45rem 1rem !important;
  transition: 0.3s;
}

.login-btn:hover {
  background-color: #dc3545;
}

.host-link {
  font-weight: 500;
  margin-right: 0.5rem;
}

.logout-btn {
  background-color: black;
  color: white !important;
  border-radius: 50px;
  padding: 0.45rem 1rem !important;
}
</style>

<nav class="navbar navbar-expand-lg sticky-top border-bottom shadow-sm">
  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-house-flag"></i>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link fw-semibold" href="/listings">
            Explore
          </a>
        </li>
      </ul>
    </div>

    <div>
      <form class="d-flex search-bar" role="search" action="/listings/search" method="GET">

        <input class="form-control me-2" type="search" name="q" placeholder="Search destinations" aria-label="Search" value="<%= searchValue || '' %>">

        <button class="btn btn-danger d-flex align-items-center gap-2 search-btn" type="submit">
          <span>Search</span>
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>

      </form>
    </div>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-center">

        <li class="nav-item">
          <a class="nav-link host-link" href="/listings/new">
            Host Your Property
          </a>
        </li>

        <% if(!currUser) { %>

          <li class="nav-item">
            <a class="nav-link signup-btn" href="/signup">
              Signup
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link login-btn" href="/login">
              Login
            </a>
          </li>

        <% } %>

        <% if(currUser) { %>

          <li class="nav-item">
            <a class="nav-link logout-btn" href="/logout">
              Logout
            </a>
          </li>

        <% } %>

      </ul>
    </div>

  </div>
</nav>
<% layout('./layouts/boilerplate') %>

<style>
  .listing-card {
    border: none;
    background: transparent;
  }

  .listing-img {
    width: 100%;
    height: 270px;
    object-fit: cover;
    border-radius: 18px;
  }

  .listing-title {
    font-size: 1rem;
    font-weight: 600;
    color: #222;
    margin-top: 10px;
    margin-bottom: 2px;
  }

  .listing-details {
    color: #6a6a6a;
    font-size: 0.95rem;
  }

  .listing-link {
    text-decoration: none;
    color: inherit;
  }
</style>

<div class="container mt-4">

  <div class="row g-4">

    <% for(let data of allData) { %>

      <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">

        <a href="/listings/<%= data._id %>" class="listing-link">

          <div class="listing-card">

            <img
              src="<%= data.image.url %>"
              alt="listing_image"
              class="listing-img">

            <div class="listing-title">
              <%= data.title %>
            </div>

            <div class="listing-details">
              <%= data.location %>
            </div>

            <div class="listing-details">
              ₹<%= data.price.toLocaleString("en-IN") %> / night
            </div>

          </div>

        </a>

      </div>

    <% } %>

  </div>

</div>
<div class="row justify-content-center">
  <div class="col-lg-10">
    <h2 class="fw-bold mb-3"><%= data.title %></h2>
    <div class="card border-0 rounded-4 overflow-hidden shadow-sm mb-4">
      <img
        src="<%= data.image.url %>"
        alt="listing_image"
        class="img-fluid"
        style="height:500px; width:100%; object-fit:cover;">
    </div>

    <div class="row g-4">

      <div class="col-lg-8">

        <div class="border-bottom pb-3 mb-3">

          <h5 class="fw-bold">
            Hosted by <%= data.owner.username %>
          </h5>

          <p class="text-muted mb-0">
            <%= data.location %>, <%= data.country %>
          </p>

        </div>

        <div class="border-bottom pb-4 mb-4">

          <h5 class="fw-bold mb-3">
            About this place
          </h5>

          <p class="text-muted lh-lg">
            <%= data.description %>
          </p>

        </div>

      </div>

      <div class="col-lg-4">

        <div class="card border-1
         rounded-4 p-4 ">

          <h3 class="fw-bold mb-4">
            ₹<%= data.price.toLocaleString("en-IN") %>
            <small class="text-muted fs-6">/ night</small>
          </h3>
          <% if(currUser && currUser._id.equals(data.owner._id)) { %>
            <a
              href="/listings/<%= data._id %>/edit"
              class="btn btn-danger w-100 mb-2">
              Edit Listing
            </a>

            <form
              action="/listings/<%= data._id %>?_method=DELETE"
              method="POST">
              <button class="btn btn-dark w-100">
                Delete Listing
              </button>
            </form>

          <% } %>
          <% if(currUser && !currUser._id.equals(data.owner._id)) { %>
          <form action="/listings/<%= data._id %>/reservation" method="GET">
            <button class="btn btn-danger w-100 mt-3">Reserve</button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>